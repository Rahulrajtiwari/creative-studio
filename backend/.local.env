#
# Template for LOCAL development (docker-compose). Copy to backend/.env and fill in.
# In production these values come from a Kubernetes ConfigMap (rendered by the
# Helm chart from Terraform-produced values-from-tf.yaml).
# -----------------------------------------------------------------------------

# --- Core ---
ENVIRONMENT="development"
LOG_LEVEL="INFO"
PROJECT_ID="<YOUR_GCP_PROJECT_ID>"
LOCATION="global"
FRONTEND_URL="http://localhost:4200"
BACKEND_URL="http://localhost:8080"
BEHIND_INGRESS=false
TRUSTED_HOSTS="*"

# --- OIDC (replaces Firebase + Google Identity Platform) ---
OIDC_ISSUER="https://login.microsoftonline.com/<TENANT_ID>/v2.0"
OIDC_AUDIENCES="api://creative-studio-dev"
OIDC_ALLOWED_EMAIL_DOMAINS="corp.example.com"
OIDC_ALLOWED_GROUPS_CLAIM="roles"
OIDC_ALLOWED_GROUPS=""
OIDC_AUTHORIZED_PARTY=""
OIDC_REQUIRE_EMAIL_VERIFIED=true
JWKS_CACHE_TTL_SEC=3600

# --- Storage ---
GENMEDIA_BUCKET="<YOUR_GCP_PROJECT_ID>-cs-dev"
SIGNING_SA_EMAIL="<YOUR_SIGNING_SA_EMAIL>"

# --- Database (matches docker-compose postgres) ---
DB_HOST="postgres"
DB_PORT="5432"
DB_USER="studio_user"
DB_PASS="studio_pass"
DB_NAME="creative_studio"
USE_CLOUD_SQL_AUTH_PROXY=false
DB_USE_IAM_AUTH=false
INSTANCE_CONNECTION_NAME=""

# --- Admin ---
ADMIN_USER_EMAIL="<YOUR_ADMIN_USER_EMAIL>"

# --- Workflows ---
BACKEND_SERVICE_ACCOUNT_EMAIL="<YOUR_GCP_SA_EMAIL>"
