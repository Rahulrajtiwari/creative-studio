#
# Production-grade defaults: regional HA, deletion protection, restricted CORS,
# Binary Authorization, group-based RBAC enforced via OIDC.
# -----------------------------------------------------------------------------

project_id  = "REPLACE_PROJECT_ID"
region      = "us-central1"
name_prefix = "cs"
labels = {
  app         = "creative-studio"
  environment = "prd"
  managed_by  = "terraform"
  data_class  = "internal"
}

network = {
  # Brownfield example: reuse existing Shared VPC + subnets.
  existing_vpc_self_link                 = ""
  existing_vpc_host_project_id           = ""
  existing_nodes_subnet_self_link        = ""
  existing_pods_secondary_range_name     = ""
  existing_services_secondary_range_name = ""
  existing_proxy_only_subnet_self_link   = ""
  existing_psc_subnet_self_link          = ""
  existing_psa_range_name                = ""
  existing_router_name                   = ""
  existing_dns_zone_name                 = ""

  vpc_name               = "cs-vpc-prd"
  nodes_subnet_name      = "cs-nodes-prd"
  nodes_cidr             = "10.40.0.0/22"
  pods_cidr              = "10.41.0.0/16"
  services_cidr          = "10.42.0.0/20"
  proxy_only_subnet_name = "cs-proxy-only-prd"
  proxy_only_subnet_cidr = "10.43.0.0/23"
  psc_subnet_name        = "cs-psc-prd"
  psc_subnet_cidr        = "10.40.4.0/28"
  psc_googleapis_ip      = "10.40.4.10"
  psa_range_name         = "cs-psa-prd"
  psa_range_cidr         = "10.44.0.0/16"
  router_name            = "cs-router-prd"
  dns_zone_name          = "cs-googleapis-prd"

  enable_nat          = true
  nat_static_ip_count = 2

  master_authorized_cidrs = [
    { cidr_block = "10.100.0.0/16", display_name = "corp-vpn" },
    { cidr_block = "10.200.0.0/16", display_name = "vdi" },
    { cidr_block = "10.250.0.0/24", display_name = "platform-bastion" },
  ]
  disallowed_cidrs = ["10.10.0.0/16", "192.168.0.0/16"]
}

gke = {
  existing_cluster_name      = ""
  existing_cluster_location  = ""
  manage_node_pools_when_byo = false

  cluster_name    = "cs-prd"
  master_cidr     = "172.16.2.0/28"
  release_channel = "STABLE"

  enable_dataplane_v2         = true
  enable_binary_authorization = true
  enable_confidential_nodes   = true
  enable_image_streaming      = true
  deletion_protection         = true
  maintenance_start_time      = "04:00"

  system_pool = {
    machine_type    = "e2-standard-4"
    min_nodes       = 3
    max_nodes       = 5
    disk_type       = "pd-ssd"
    disk_size_gb    = 100
    spot            = false
    max_surge       = 1
    max_unavailable = 0
  }

  app_pool = {
    machine_type    = "n2-standard-8"
    min_nodes       = 3
    max_nodes       = 20
    disk_type       = "pd-ssd"
    disk_size_gb    = 200
    spot            = false
    max_surge       = 2
    max_unavailable = 0
  }
}

cloudsql = {
  database_version         = "POSTGRES_15"
  tier                     = "db-custom-4-15360"
  availability_type        = "REGIONAL"
  disk_size_gb             = 100
  disk_autoresize_limit_gb = 1000
  deletion_protection      = true
  db_name                  = "creative_studio"
  db_user                  = "studio_user"
  db_password_secret_id    = "creative-studio-db-password-prd"
  existing_instance_name   = ""
  manage_db_and_users      = true
}

gcs = {
  bucket_name       = "REPLACE_PROJECT_ID-cs-prd"
  cors_origins      = ["https://creative-studio.corp.example.com"]
  access_log_bucket = "REPLACE_PROJECT_ID-access-logs"
}

artifact_registry = {
  repository_id = "creative-studio-prd"
}

lb_config = {
  certificate_name     = "creative-studio-prd-cert"
  cert_pem_secret_id   = "creative-studio-prd-tls-crt"
  key_pem_secret_id    = "creative-studio-prd-tls-key"
  lb_static_ip_address = ""
}

app = {
  namespace          = "creative-studio"
  fqdn               = "creative-studio.corp.example.com"
  backend_image_tag  = "REPLACE_WITH_RELEASE_TAG"
  frontend_image_tag = "REPLACE_WITH_RELEASE_TAG"

  oidc = {
    issuer                 = "https://login.microsoftonline.com/REPLACE_TENANT_ID/v2.0"
    audiences              = ["api://creative-studio"]
    frontend_client_id     = "REPLACE_FRONTEND_CLIENT_ID"
    allowed_email_domains  = ["corp.example.com"]
    allowed_groups_claim   = "roles"
    allowed_groups         = ["creative-studio-users", "creative-studio-admins"]
    authorized_party       = "REPLACE_SPA_CLIENT_ID"
    jwks_cache_ttl_seconds = 1800
    idp_display_name       = "Corporate SSO"
  }

  backend_signing_sa_email = "cs-be-prd@REPLACE_PROJECT_ID.iam.gserviceaccount.com"
  workflows_executor_url   = ""
}
