#
# Copy to dev.tfvars and fill in real values. Every CIDR is mandatory even
# for fresh creates so we never auto-pick conflicting ranges.
# -----------------------------------------------------------------------------

project_id  = "REPLACE_PROJECT_ID"
region      = "us-central1"
name_prefix = "cs"

labels = {
  app         = "creative-studio"
  environment = "dev"
  managed_by  = "terraform"
}

# -----------------------------------------------------------------------------
# Network
# -----------------------------------------------------------------------------
network = {
  # === BYO toggles (set to "" to create fresh; populate to reuse existing) ===
  existing_vpc_self_link                 = ""
  existing_vpc_host_project_id           = ""
  existing_nodes_subnet_self_link        = ""
  existing_pods_secondary_range_name     = ""
  existing_services_secondary_range_name = ""
  existing_proxy_only_subnet_self_link   = ""
  existing_psc_subnet_self_link          = ""
  existing_psa_range_name                = ""
  existing_router_name                   = ""
  existing_dns_zone_name                 = ""

  # === Create-mode (always required) ===
  vpc_name               = "cs-vpc-dev"
  nodes_subnet_name      = "cs-nodes-dev"
  nodes_cidr             = "10.20.0.0/22"
  pods_cidr              = "10.21.0.0/16"
  services_cidr          = "10.22.0.0/20"
  proxy_only_subnet_name = "cs-proxy-only-dev"
  proxy_only_subnet_cidr = "10.23.0.0/23"
  psc_subnet_name        = "cs-psc-dev"
  psc_subnet_cidr        = "10.20.4.0/28"
  psc_googleapis_ip      = "10.20.4.10"
  psa_range_name         = "cs-psa-dev"
  psa_range_cidr         = "10.24.0.0/16"
  router_name            = "cs-router-dev"
  dns_zone_name          = "cs-googleapis-dev"

  enable_nat          = true
  nat_static_ip_count = 1

  master_authorized_cidrs = [
    { cidr_block = "10.100.0.0/16", display_name = "corp-vpn" },
    { cidr_block = "10.200.0.0/16", display_name = "vdi" },
  ]
  disallowed_cidrs = ["10.10.0.0/16", "192.168.0.0/16"]
}

# -----------------------------------------------------------------------------
# GKE
# -----------------------------------------------------------------------------
gke = {
  existing_cluster_name      = ""
  existing_cluster_location  = ""
  manage_node_pools_when_byo = false

  cluster_name    = "cs-dev"
  master_cidr     = "172.16.0.0/28"
  release_channel = "REGULAR"

  enable_dataplane_v2         = true
  enable_binary_authorization = false
  enable_confidential_nodes   = false
  enable_image_streaming      = true
  deletion_protection         = false # dev only
  maintenance_start_time      = "03:00"

  system_pool = {
    machine_type    = "e2-standard-4"
    min_nodes       = 1
    max_nodes       = 2
    disk_type       = "pd-balanced"
    disk_size_gb    = 100
    spot            = false
    max_surge       = 1
    max_unavailable = 0
  }

  app_pool = {
    machine_type    = "n2-standard-4"
    min_nodes       = 1
    max_nodes       = 4
    disk_type       = "pd-balanced"
    disk_size_gb    = 200
    spot            = false
    max_surge       = 1
    max_unavailable = 0
  }
}

# -----------------------------------------------------------------------------
# Cloud SQL
# -----------------------------------------------------------------------------
cloudsql = {
  database_version         = "POSTGRES_15"
  tier                     = "db-custom-1-3840"
  availability_type        = "ZONAL"
  disk_size_gb             = 20
  disk_autoresize_limit_gb = 100
  deletion_protection      = false
  db_name                  = "creative_studio"
  db_user                  = "studio_user"
  db_password_secret_id    = "creative-studio-db-password-dev"
}

# -----------------------------------------------------------------------------
# GCS bucket
# -----------------------------------------------------------------------------
gcs = {
  bucket_name       = "REPLACE_PROJECT_ID-cs-dev"
  cors_origins      = ["https://creative-studio.dev.corp.example.com"]
  access_log_bucket = "REPLACE_PROJECT_ID-access-logs"
}

# -----------------------------------------------------------------------------
# Artifact Registry
# -----------------------------------------------------------------------------
artifact_registry = {
  repository_id = "creative-studio-dev"
  extra_writers = [
    # CI service account email for pushes
    # "serviceAccount:cloudbuild-pwp-sa@REPLACE_PROJECT_ID.iam.gserviceaccount.com",
  ]
}

# -----------------------------------------------------------------------------
# Internal LB cert (corp PKI uploaded to Secret Manager)
# -----------------------------------------------------------------------------
ilb_cert = {
  certificate_name      = "creative-studio-dev-cert"
  cert_pem_secret_id    = "creative-studio-dev-tls-crt"
  key_pem_secret_id     = "creative-studio-dev-tls-key"
  ilb_static_ip_address = "10.20.0.50"
}

# -----------------------------------------------------------------------------
# Application config
# -----------------------------------------------------------------------------
app = {
  namespace          = "creative-studio"
  fqdn               = "creative-studio.dev.corp.example.com"
  backend_image_tag  = "latest"
  frontend_image_tag = "latest"

  oidc = {
    issuer                 = "https://login.microsoftonline.com/REPLACE_TENANT_ID/v2.0"
    audiences              = ["api://creative-studio-dev"]
    frontend_client_id     = "REPLACE_FRONTEND_CLIENT_ID"
    allowed_email_domains  = ["corp.example.com"]
    allowed_groups_claim   = "roles"
    allowed_groups         = []
    authorized_party       = ""
    jwks_cache_ttl_seconds = 3600
    idp_display_name       = "Corporate SSO"
  }

  backend_signing_sa_email = "cs-be-dev@REPLACE_PROJECT_ID.iam.gserviceaccount.com"
  workflows_executor_url   = ""
}
