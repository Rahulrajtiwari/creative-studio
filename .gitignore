__pycache__
.venv
venv
local/
.env
.DS_Store
*.key
*.crt

.aider*
.vscode

# Terraform state and providers
/.terraform/

# Terraform: ignore all environments/* content by default (state, tfvars, etc.)
**/environments/*

# But re-include the Terraform root configs (main.tf, variables.tf, etc.)
!**/environments/dev/
!**/environments/qat/
!**/environments/prd/
!**/environments/dev/*.tf
!**/environments/qat/*.tf
!**/environments/prd/*.tf
!**/environments/*/*.example

# Explicitly ignore actual tfvars (secrets) and generated files
**/environments/**/tfplan
**/environments/**/*.tfvars
!**/environments/**/*.tfvars.example
**/environments/**/generated/
**/environments/**/.terraform/
**/environments/**/.terraform.lock.hcl
**/environments/**/terraform.tfstate*

